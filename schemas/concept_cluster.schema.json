{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ConceptClusterResult",
  "type": "object",
  "required": [
    "seed",
    "variants",
    "cluster_summary",
    "gaps",
    "capability_status",
    "unsupported_sources",
    "confidence"
  ],
  "properties": {
    "seed": {
      "type": "object",
      "required": ["seed", "seed_kind"],
      "properties": {
        "seed": { "type": "string" },
        "seed_kind": { "type": "string" }
      }
    },
    "variants": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "entry_anchor",
          "route",
          "constraints",
          "related_tests",
          "confidence",
          "gaps"
        ],
        "properties": {
          "id": { "type": "string" },
          "entry_anchor": {
            "type": "object",
            "required": ["path", "language"],
            "properties": {
              "path": { "type": "string" },
              "language": { "type": "string" },
              "symbol": { "type": "string" },
              "kind": { "type": "string" },
              "line": { "type": "integer", "minimum": 0 },
              "column": { "type": "integer", "minimum": 0 }
            }
          },
          "body_anchor": {
            "type": "object",
            "required": ["path", "language"],
            "properties": {
              "path": { "type": "string" },
              "language": { "type": "string" },
              "symbol": { "type": "string" },
              "kind": { "type": "string" },
              "line": { "type": "integer", "minimum": 0 },
              "column": { "type": "integer", "minimum": 0 }
            }
          },
          "route": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "kind",
                "path",
                "language",
                "evidence",
                "relation_kind",
                "source_kind",
                "score"
              ],
              "properties": {
                "kind": { "type": "string" },
                "path": { "type": "string" },
                "language": { "type": "string" },
                "evidence": { "type": "string" },
                "anchor_symbol": { "type": "string" },
                "source_span": {
                  "type": "object",
                  "required": ["start_line", "end_line"],
                  "properties": {
                    "start_line": { "type": "integer", "minimum": 0 },
                    "end_line": { "type": "integer", "minimum": 0 },
                    "start_column": { "type": "integer", "minimum": 0 },
                    "end_column": { "type": "integer", "minimum": 0 }
                  }
                },
                "relation_kind": { "type": "string" },
                "source_kind": { "type": "string" },
                "score": { "type": "number" }
              }
            }
          },
          "constraints": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "kind",
                "strength",
                "scope",
                "source_path",
                "confidence",
                "normalized_text"
              ],
              "properties": {
                "kind": { "type": "string" },
                "strength": { "type": "string" },
                "scope": { "type": "string" },
                "source_path": { "type": "string" },
                "source_span": {
                  "type": "object",
                  "required": ["start_line", "end_line"],
                  "properties": {
                    "start_line": { "type": "integer", "minimum": 0 },
                    "end_line": { "type": "integer", "minimum": 0 },
                    "start_column": { "type": "integer", "minimum": 0 },
                    "end_column": { "type": "integer", "minimum": 0 }
                  }
                },
                "introduced_by": { "type": "string" },
                "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
                "normalized_text": { "type": "string" }
              }
            }
          },
          "related_tests": {
            "type": "array",
            "items": { "type": "string" }
          },
          "lexical_proximity": { "type": "number", "minimum": 0, "maximum": 1 },
          "semantic_proximity": { "type": "number", "minimum": 0, "maximum": 1 },
          "route_centrality": { "type": "number", "minimum": 0, "maximum": 1 },
          "symbol_overlap": { "type": "number", "minimum": 0, "maximum": 1 },
          "constraint_overlap": { "type": "number", "minimum": 0, "maximum": 1 },
          "test_adjacency": { "type": "number", "minimum": 0, "maximum": 1 },
          "semantic_state": {
            "type": "string",
            "oneOf": [
              { "const": "used" },
              { "const": "disabled_low_signal" },
              { "const": "unavailable_fail_open" },
              { "const": "not_applicable" }
            ]
          },
          "score_model": { "type": "string" },
          "score_breakdown": {
            "type": "object",
            "properties": {
              "lexical": { "type": "number", "minimum": 0, "maximum": 1 },
              "semantic": { "type": "number", "minimum": 0, "maximum": 1 },
              "route": { "type": "number", "minimum": 0, "maximum": 1 },
              "symbol": { "type": "number", "minimum": 0, "maximum": 1 },
              "constraint": { "type": "number", "minimum": 0, "maximum": 1 },
              "test": { "type": "number", "minimum": 0, "maximum": 1 },
              "penalties": { "type": "number", "minimum": 0, "maximum": 1 },
              "final": { "type": "number", "minimum": 0, "maximum": 1 }
            }
          },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "gaps": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "cluster_summary": {
      "type": "object",
      "required": ["variant_count", "languages", "route_kinds"],
      "properties": {
        "variant_count": { "type": "integer", "minimum": 0 },
        "languages": {
          "type": "array",
          "items": { "type": "string" }
        },
        "route_kinds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "expansion_sources": {
          "type": "array",
          "items": { "type": "string" }
        },
        "expansion_policy": {
          "type": "object",
          "required": [
            "initial_sources",
            "enrichment_sources",
            "feedback_sources",
            "route_trace_reused",
            "candidate_pool_limit_multiplier",
            "dedup_unit",
            "tie_break_order"
          ],
          "properties": {
            "initial_sources": {
              "type": "array",
              "items": { "type": "string" }
            },
            "enrichment_sources": {
              "type": "array",
              "items": { "type": "string" }
            },
            "feedback_sources": {
              "type": "array",
              "items": { "type": "string" }
            },
            "route_trace_reused": { "type": "boolean" },
            "candidate_pool_limit_multiplier": {
              "type": "integer",
              "minimum": 1
            },
            "dedup_unit": { "type": "string" },
            "tie_break_order": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "cutoff_policy": { "type": "string" },
        "dedup_policy": { "type": "string" }
      }
    },
    "gaps": {
      "type": "array",
      "items": { "type": "string" }
    },
    "capability_status": { "type": "string" },
    "unsupported_sources": {
      "type": "array",
      "items": { "type": "string" }
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
  }
}
