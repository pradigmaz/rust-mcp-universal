{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "QueryReport",
  "type": "object",
  "required": [
    "query_id",
    "timestamp_utc",
    "project_root",
    "resolved_mode",
    "mode_source",
    "budget",
    "retrieval_pipeline",
    "selected_context",
    "provenance",
    "confidence",
    "gaps",
    "index_telemetry",
    "degradation_reasons",
    "deepen_available"
  ],
  "properties": {
    "query_id": { "type": "string" },
    "timestamp_utc": { "type": "string" },
    "project_root": { "type": "string" },
    "resolved_mode": {
      "type": "string",
      "oneOf": [
        { "const": "entrypoint_map" },
        { "const": "test_map" },
        { "const": "review_prep" },
        { "const": "api_contract_map" },
        { "const": "runtime_surface" },
        { "const": "refactor_surface" }
      ]
    },
    "mode_source": {
      "type": "string",
      "oneOf": [
        { "const": "explicit" },
        { "const": "inferred" },
        { "const": "default" }
      ]
    },
    "budget": {
      "type": "object",
      "required": ["max_tokens", "used_estimate", "hard_truncated"],
      "properties": {
        "max_tokens": { "type": "integer", "minimum": 0 },
        "used_estimate": { "type": "integer", "minimum": 0 },
        "hard_truncated": { "type": "boolean" }
      }
    },
    "retrieval_pipeline": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["stage", "candidates", "kept"],
        "properties": {
          "stage": { "type": "string" },
          "candidates": { "type": "integer", "minimum": 0 },
          "kept": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "selected_context": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "score",
          "chars",
          "chunk_idx",
          "start_line",
          "end_line",
          "chunk_source",
          "why",
          "explain",
          "provenance"
        ],
        "properties": {
          "path": { "type": "string" },
          "score": { "type": "number" },
          "chars": { "type": "integer", "minimum": 0 },
          "chunk_idx": { "type": "integer", "minimum": 0 },
          "start_line": { "type": "integer", "minimum": 0 },
          "end_line": { "type": "integer", "minimum": 0 },
          "chunk_source": { "type": "string" },
          "why": { "type": "array", "items": { "type": "string" } },
          "explain": {
            "type": "object",
            "required": [
              "lexical",
              "graph",
              "semantic",
              "rrf",
              "graph_rrf",
              "rank_before",
              "rank_after",
              "semantic_source",
              "semantic_outcome",
              "graph_seed_path",
              "graph_edge_kinds",
              "graph_hops"
            ],
            "properties": {
              "lexical": { "type": "number" },
              "graph": { "type": "number" },
              "semantic": { "type": "number" },
              "rrf": { "type": "number" },
              "graph_rrf": { "type": "number" },
              "rank_before": { "type": "integer", "minimum": 1 },
              "rank_after": { "type": "integer", "minimum": 1 },
              "semantic_source": { "type": "string" },
              "semantic_outcome": { "type": "string" },
              "graph_seed_path": { "type": "string" },
              "graph_edge_kinds": {
                "type": "array",
                "items": { "type": "string" }
              },
              "graph_hops": { "type": "integer", "minimum": 0 }
            }
          },
          "provenance": { "$ref": "./canonical_provenance.schema.json" }
        }
      }
    },
    "provenance": { "$ref": "./canonical_provenance.schema.json" },
    "confidence": {
      "type": "object",
      "required": ["overall", "reasons", "signals"],
      "properties": {
        "overall": { "type": "number", "minimum": 0, "maximum": 1 },
        "reasons": { "type": "array", "items": { "type": "string" } },
        "signals": {
          "type": "object",
          "required": [
            "margin_top1_top2",
            "explain_coverage",
            "semantic_coverage",
            "semantic_outcome",
            "stage_drop_ratio",
            "hard_truncated"
          ],
          "properties": {
            "margin_top1_top2": { "type": "number", "minimum": 0 },
            "explain_coverage": { "type": "number", "minimum": 0, "maximum": 1 },
            "semantic_coverage": { "type": "number", "minimum": 0, "maximum": 1 },
            "semantic_outcome": { "type": "string" },
            "stage_drop_ratio": { "type": "number", "minimum": 0, "maximum": 1 },
            "hard_truncated": { "type": "boolean" }
          }
        }
      }
    },
    "gaps": {
      "type": "array",
      "items": { "type": "string" }
    },
    "index_telemetry": {
      "type": "object",
      "required": [
        "last_index_lock_wait_ms",
        "last_embedding_cache_hits",
        "last_embedding_cache_misses",
        "chunk_coverage",
        "chunk_source"
      ],
      "properties": {
        "last_index_lock_wait_ms": { "type": "integer", "minimum": 0 },
        "last_embedding_cache_hits": { "type": "integer", "minimum": 0 },
        "last_embedding_cache_misses": { "type": "integer", "minimum": 0 },
        "chunk_coverage": { "type": "number", "minimum": 0, "maximum": 1 },
        "chunk_source": { "type": "string" }
      }
    },
    "degradation_reasons": {
      "type": "array",
      "items": {
        "type": "string",
        "oneOf": [
          { "const": "semantic_fail_open" },
          { "const": "semantic_low_signal_skip" },
          { "const": "chunk_preview_fallback" },
          { "const": "budget_truncated" },
          { "const": "profile_limited" },
          { "const": "unsupported_sources_present" }
        ]
      }
    },
    "deepen_available": { "type": "boolean" },
    "deepen_hint": { "type": "string" },
    "investigation_summary": {
      "type": "object",
      "required": [
        "concept_cluster",
        "route_trace",
        "constraint_evidence",
        "surface_kind",
        "provenance"
      ],
      "properties": {
        "surface_kind": { "type": "string" },
        "concept_cluster": {
          "type": "object",
          "required": ["variant_count", "top_variants"],
          "properties": {
            "variant_count": { "type": "integer", "minimum": 0 },
            "top_variants": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["path", "confidence"],
                "properties": {
                  "path": { "type": "string" },
                  "symbol": { "type": "string" },
                  "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
                }
              }
            }
          }
        },
        "route_trace": {
          "type": "object",
          "required": [
            "best_route_segment_count",
            "alternate_route_count",
            "unresolved_gap_count",
            "segment_kinds",
            "capability_status"
          ],
          "properties": {
            "best_route_segment_count": { "type": "integer", "minimum": 0 },
            "alternate_route_count": { "type": "integer", "minimum": 0 },
            "unresolved_gap_count": { "type": "integer", "minimum": 0 },
            "segment_kinds": { "type": "array", "items": { "type": "string" } },
            "unsupported_sources": {
              "type": "array",
              "items": { "type": "string" }
            },
            "capability_status": { "type": "string" }
          }
        },
        "constraint_evidence": {
          "type": "object",
          "required": [
            "total",
            "strong",
            "weak",
            "constraint_kinds",
            "normalized_keys",
            "capability_status"
          ],
          "properties": {
            "total": { "type": "integer", "minimum": 0 },
            "strong": { "type": "integer", "minimum": 0 },
            "weak": { "type": "integer", "minimum": 0 },
            "constraint_kinds": { "type": "array", "items": { "type": "string" } },
            "normalized_keys": { "type": "array", "items": { "type": "string" } },
            "unsupported_sources": {
              "type": "array",
              "items": { "type": "string" }
            },
            "capability_status": { "type": "string" }
          }
        },
        "divergence": {
          "type": "object",
          "required": [
            "surface_kind",
            "authoritative_tool",
            "preview_only",
            "highest_severity",
            "signal_count",
            "recommended_followups",
            "capability_status"
          ],
          "properties": {
            "surface_kind": { "type": "string" },
            "authoritative_tool": { "type": "string" },
            "preview_only": { "type": "boolean" },
            "highest_severity": { "type": "string" },
            "signal_count": { "type": "integer", "minimum": 0 },
            "recommended_followups": { "type": "array", "items": { "type": "string" } },
            "unsupported_sources": {
              "type": "array",
              "items": { "type": "string" }
            },
            "capability_status": { "type": "string" }
          }
        },
        "provenance": { "$ref": "./canonical_provenance.schema.json" }
      }
    },
    "timings": {
      "type": "object",
      "required": [
        "search_ms",
        "context_ms",
        "investigation_ms",
        "format_ms",
        "total_ms",
        "investigation"
      ],
      "properties": {
        "search_ms": { "type": "integer", "minimum": 0 },
        "context_ms": { "type": "integer", "minimum": 0 },
        "investigation_ms": { "type": "integer", "minimum": 0 },
        "format_ms": { "type": "integer", "minimum": 0 },
        "total_ms": { "type": "integer", "minimum": 0 },
        "investigation": {
          "type": "object",
          "required": [
            "cluster_ms",
            "route_ms",
            "constraints_ms",
            "divergence_ms"
          ],
          "properties": {
            "cluster_ms": { "type": "integer", "minimum": 0 },
            "route_ms": { "type": "integer", "minimum": 0 },
            "constraints_ms": { "type": "integer", "minimum": 0 },
            "divergence_ms": { "type": "integer", "minimum": 0 }
          }
        }
      }
    }
  }
}
