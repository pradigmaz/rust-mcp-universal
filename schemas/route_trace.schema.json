{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RouteTraceResult",
  "type": "object",
  "required": [
    "seed",
    "best_route",
    "alternate_routes",
    "unresolved_gaps",
    "capability_status",
    "unsupported_sources",
    "confidence"
  ],
  "properties": {
    "seed": {
      "type": "object",
      "required": ["seed", "seed_kind"],
      "properties": {
        "seed": { "type": "string" },
        "seed_kind": { "type": "string" }
      }
    },
    "best_route": {
      "type": "object",
      "required": [
        "segments",
        "total_hops",
        "total_weight",
        "collapsed_hops",
        "confidence"
      ],
      "properties": {
        "segments": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "kind",
              "path",
              "language",
              "evidence",
              "relation_kind",
              "source_kind",
              "score"
            ],
            "properties": {
              "kind": { "type": "string" },
              "path": { "type": "string" },
              "language": { "type": "string" },
              "evidence": { "type": "string" },
              "anchor_symbol": { "type": "string" },
              "source_span": {
                "type": "object",
                "required": ["start_line", "end_line"],
                "properties": {
                  "start_line": { "type": "integer", "minimum": 0 },
                  "end_line": { "type": "integer", "minimum": 0 },
                  "start_column": { "type": "integer", "minimum": 0 },
                  "end_column": { "type": "integer", "minimum": 0 }
                }
              },
              "relation_kind": { "type": "string" },
              "source_kind": { "type": "string" },
              "score": { "type": "number" }
            }
          }
        },
        "total_hops": { "type": "integer", "minimum": 0 },
        "total_weight": { "type": "number" },
        "collapsed_hops": { "type": "integer", "minimum": 0 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "alternate_routes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "segments",
          "total_hops",
          "total_weight",
          "collapsed_hops",
          "confidence"
        ],
        "properties": {
          "segments": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "kind",
                "path",
                "language",
                "evidence",
                "relation_kind",
                "source_kind",
                "score"
              ],
              "properties": {
                "kind": { "type": "string" },
                "path": { "type": "string" },
                "language": { "type": "string" },
                "evidence": { "type": "string" },
                "anchor_symbol": { "type": "string" },
                "source_span": {
                  "type": "object",
                  "required": ["start_line", "end_line"],
                  "properties": {
                    "start_line": { "type": "integer", "minimum": 0 },
                    "end_line": { "type": "integer", "minimum": 0 },
                    "start_column": { "type": "integer", "minimum": 0 },
                    "end_column": { "type": "integer", "minimum": 0 }
                  }
                },
                "relation_kind": { "type": "string" },
                "source_kind": { "type": "string" },
                "score": { "type": "number" }
              }
            }
          },
          "total_hops": { "type": "integer", "minimum": 0 },
          "total_weight": { "type": "number" },
          "collapsed_hops": { "type": "integer", "minimum": 0 },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "unresolved_gaps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["reason"],
        "properties": {
          "from_kind": { "type": "string" },
          "to_kind": { "type": "string" },
          "reason": { "type": "string" },
          "last_resolved_path": { "type": "string" }
        }
      }
    },
    "capability_status": { "type": "string" },
    "unsupported_sources": {
      "type": "array",
      "items": { "type": "string" }
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
  }
}
